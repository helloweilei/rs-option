{
  "name": "rs-option",
  "version": "1.0.1",
  "description": "Option type library inspired by Rust",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c",
    "build:tsc": "tsc",
    "test": "vitest"
  },
  "keywords": [
    "option",
    "rust",
    "typescript",
    "functional"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/helloweilei/rs-option.git"
  },
  "bugs": {
    "url": "https://github.com/helloweilei/rs-option/issues"
  },
  "homepage": "https://github.com/helloweilei/rs-option#readme",
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^25.3.3",
    "@vitest/ui": "^4.0.18",
    "rollup": "^4.59.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
